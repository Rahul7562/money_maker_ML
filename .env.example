# Binance credentials (required for LIVE mode only)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# -----------------------------------------------------------------------------
# Balanced Profile (recommended for most Linux VPS)
# -----------------------------------------------------------------------------

# Core mode
PAPER_TRADING=true
MARKET_MODE=SPOT
TRADE_INTERVAL=1h
QUOTE_ASSET=USDT

# Universe and data load
MAX_SYMBOLS_ANALYZED=24
MIN_24H_QUOTE_VOLUME=20000000
CANDLES_LIMIT=250

# Signal quality and regime filters
MIN_SIGNAL_SCORE=0.60
MIN_CONFIDENCE=0.62
MIN_SCORE_FOR_SLOT_2_PLUS=0.66
SIDEWAYS_MIN_SCORE=0.70
ALLOW_SIDEWAYS_TRADES=true

# Risk controls (balanced)
MAX_TRADE_PERCENT=0.10
MIN_TRADE_PERCENT=0.03
MAX_OPEN_POSITIONS=3
MAX_DAILY_DRAWDOWN_PERCENT=4.5
STOP_LOSS_PERCENT=0.018
TAKE_PROFIT_PERCENT=0.045
TRAILING_STOP_MULTIPLIER=1.2
ATR_STOP_MULTIPLIER=1.5

# Adaptive tuning
WFO_ENABLED=true
WFO_REOPTIMIZE_EVERY_CYCLES=8
WFO_MAX_SYMBOLS=3
WFO_MAX_PARAMETER_SETS=32
WFO_TIME_BUDGET_SECONDS=10
WFO_EMA_FAST_CANDIDATES=10,12,16,20,26
WFO_EMA_SLOW_CANDIDATES=34,40,50,70
WFO_RSI_PERIOD_CANDIDATES=10,14,18
WFO_MACD_FAST_CANDIDATES=8,12,16
WFO_MACD_SLOW_CANDIDATES=21,26,34
WFO_MACD_SIGNAL_CANDIDATES=7,9,12
WFO_ATR_PERIOD_CANDIDATES=10,14,21
WFO_MIN_SCORE_CANDIDATES=0.54,0.58,0.62,0.66
WFO_RSI_OVERSOLD_CANDIDATES=26,28,32,36
WFO_RSI_OVERBOUGHT_CANDIDATES=64,68,72,76

# Performance helpers
CORRELATION_FILTER_ENABLED=true
CORRELATION_THRESHOLD=0.85
CORRELATION_LOOKBACK=50
SENTIMENT_ENABLED=true

# Resource usage (set to true for research, false for production throughput)
SIMULATION_ENABLED=false
ML_ENABLED=true

# Execution
PAPER_ORDER_TYPE=MARKET
SLIPPAGE_STD=0.0003

# Logging and state
LOG_FILE=bot.log
LOG_ROTATION_MB=50
LOG_MAX_BACKUPS=5
STATE_DIR=state/
HEALTH_CHECK_PORT=8080

# Paper-to-live readiness report
PAPER_GRADUATION_MIN_TRADES=40
PAPER_GRADUATION_MIN_WIN_RATE=0.55
PAPER_GRADUATION_MIN_PROFIT_FACTOR=1.20
PAPER_GRADUATION_MIN_TOTAL_PNL_USDT=10
PAPER_GRADUATION_MAX_DRAWDOWN=8.0
WEEKLY_REPORT_WINDOW_DAYS=7
WEEKLY_REPORT_EVERY_HOURS=6

# -----------------------------------------------------------------------------
# Optional quick profile overrides
# -----------------------------------------------------------------------------
# High-performance VM (4GB+ RAM):
#   MAX_SYMBOLS_ANALYZED=35
#   MAX_OPEN_POSITIONS=4
#   SIMULATION_ENABLED=true
#   ML_ENABLED=true
#   WFO_MAX_PARAMETER_SETS=48
#   WFO_TIME_BUDGET_SECONDS=14
#
# Low-memory VM (1GB RAM):
#   MAX_SYMBOLS_ANALYZED=15
#   MAX_OPEN_POSITIONS=3
#   ML_ENABLED=false
#   SIMULATION_ENABLED=false
